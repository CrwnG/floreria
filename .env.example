# Database (Supabase PostgreSQL - use Session Pooler for IPv4 compatibility)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# NextAuth - generate with: openssl rand -base64 32
AUTH_SECRET="change-this-to-a-random-32-char-string"

# Mercado Pago - get credentials at: https://www.mercadopago.com.mx/developers/panel/app
MP_ACCESS_TOKEN="TEST-your-access-token-here"
MP_PUBLIC_KEY="TEST-your-public-key-here"

# App URL (REQUIRED - used for Mercado Pago callbacks and webhooks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WhatsApp business number (country code + number, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER="522221234567"

# Cloudinary - get credentials at: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Admin seed credentials (only used by: npx tsx prisma/seed.ts)
ADMIN_EMAIL="admin@fiorella.mx"
ADMIN_PASSWORD="change-this-password"
